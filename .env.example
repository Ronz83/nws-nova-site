# ─────────────────────────────────────────────
# NWS Nova Site — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# ── GHL (GoHighLevel) Connector ──────────────
# Your GHL Location API key (Settings → API Keys)
VITE_GHL_API_KEY=

# GHL Location ID (Settings → Business Profile)
VITE_GHL_LOCATION_ID=

# GHL Sub-account API base (usually https://rest.gohighlevel.com/v1)
VITE_GHL_API_BASE=https://rest.gohighlevel.com/v1

# GHL Calendar ID for booking widget
VITE_GHL_CALENDAR_ID=7XM9CtPbOpvqKfdXXFeq

# ── NWS Backend API (Nova AI / Antigravity connector) ──
VITE_API_URL=https://antigravity-app-9ao8.onrender.com

# ── Supabase (About page mission entries) ────
VITE_SUPABASE_URL=https://jtfyiotugsiolyzmjwvj.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Analytics (optional) ─────────────────────
VITE_GA_MEASUREMENT_ID=
